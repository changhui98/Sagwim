# API 기본 URL — 환경별 옵션:
# 시뮬레이터: http://localhost:8080/api/v1
# 실기기(LAN): http://192.168.x.x:8080/api/v1  ← ifconfig | grep "inet " 로 Mac LAN IP 확인 후 교체
# 실기기(ngrok): https://xxxx.ngrok-free.app/api/v1
# 운영: https://sagwim.com/api/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# 카카오 OAuth — REST API 키 (Kakao Developers 콘솔 > 앱 설정 > 앱 키)
# Redirect URI 허용 설정: 카카오 콘솔 > 카카오 로그인 > Redirect URI에 아래 값 추가 필요
#   sagwim://oauth  (Standalone 빌드)
#   exp://127.0.0.1:8081/--/oauth  (Expo Go 개발 환경 — 실제 포트는 Metro 출력 확인)
EXPO_PUBLIC_KAKAO_CLIENT_ID=

# 구글 OAuth — iOS용 클라이언트 ID (Google Cloud Console > API 및 서비스 > 사용자 인증 정보)
# 클라이언트 유형: iOS
# 번들 ID: com.peopleground.sagwim.app
# Redirect URI: 구글은 com.googleusercontent.apps.<CLIENT_ID>:/ 형태를 자동 처리함
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
